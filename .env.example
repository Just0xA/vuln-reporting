# =============================================================================
# Tenable Vulnerability Management — API Credentials
# Obtain from: Tenable.io > Settings > My Account > API Keys
# =============================================================================
TVM_ACCESS_KEY=your_access_key_here
TVM_SECRET_KEY=your_secret_key_here

# Base URL for Tenable.io (do not change unless using on-prem / SC)
TVM_URL=https://cloud.tenable.com

# =============================================================================
# SMTP — Email Delivery
# Office 365 defaults are shown; adjust HOST/PORT for other providers
# =============================================================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587                           # 587 = STARTTLS (default), 465 = SSL

# Credentials for the sending mailbox
SMTP_USERNAME=reports@yourcompany.com
SMTP_PASSWORD=your_smtp_password

# Display name and address shown in the From header
SMTP_FROM_ADDRESS=reports@yourcompany.com
SMTP_FROM_NAME=Vulnerability Management Reports

# =============================================================================
# Optional overrides
# =============================================================================
# Maximum total attachment size in MB before Excel attachments are dropped
# MAX_ATTACHMENT_SIZE_MB=25

# Force SMTP over SSL instead of STARTTLS (set to "true" if using port 465)
# SMTP_USE_SSL=false

# Override log level (DEBUG | INFO | WARNING | ERROR)
# LOG_LEVEL=INFO
